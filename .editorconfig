root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.cs]
indent_style = tab
indent_size = 4
tab_width = 4

[*.{tscn,tres,godot,import}]
indent_style = space
indent_size = 4

[*.{json,md,yml,y.yaml}]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false
