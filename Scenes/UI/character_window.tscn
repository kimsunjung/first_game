[gd_scene format=3]

[ext_resource type="Script" path="res://Scripts/UI/CharacterWindow.cs" id="1_cw"]

[node name="CharacterWindow" type="CanvasLayer"]
process_mode = 3
script = ExtResource("1_cw")

[node name="PanelContainer" type="PanelContainer" parent="."]
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -180.0
offset_top = -220.0
offset_right = 180.0
offset_bottom = 220.0
grow_horizontal = 2
grow_vertical = 2

[node name="VBoxContainer" type="VBoxContainer" parent="PanelContainer"]
layout_mode = 2
theme_override_constants/separation = 6

[node name="TitleLabel" type="Label" parent="PanelContainer/VBoxContainer"]
layout_mode = 2
theme_override_font_sizes/font_size = 18
text = "캐릭터 정보  [C]"
horizontal_alignment = 1

[node name="LevelInfo" type="Label" parent="PanelContainer/VBoxContainer"]
