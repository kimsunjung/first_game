[gd_scene format=3]

[ext_resource type="Script" path="res://Scripts/UI/MainMenu.cs" id="1_menu"]
[ext_resource type="PackedScene" path="res://Scenes/UI/settings_ui.tscn" id="2_settings"]

[node name="MainMenu" type="CanvasLayer"]
script = ExtResource("1_menu")

[node name="Background" type="ColorRect" parent="."]
texture_filter = 2
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.08, 0.08, 0.15, 1)

[node name="CenterContainer" type="CenterContainer" parent="."]
texture_filter = 2
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="VBox" type="VBoxContainer" parent="CenterContainer"]
layout_mode = 2
theme_override_constants/separation = 16

[node name="Title" type="Label" parent="CenterContainer/VBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 18
text = "Sandbox Mobile RPG"
horizontal_alignment = 1

[node name="Subtitle" type="Label" parent="CenterContainer/VBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 12
modulate = Color(0.6, 0.6, 0.7, 1)
text = "v0.1 Early Development"
horizontal_alignment = 1

[node name="Spacer" type="Control" parent="CenterContainer/VBox"]
layout_mode = 2
custom_minimum_size = Vector2(0, 24)

[node name="NewGameBtn" type="Button" parent="CenterContainer/VBox"]
unique_name_in_owner = true
layout_mode = 2
custom_minimum_size = Vector2(200, 44)
text = "새 게임"

[node name="ContinueBtn" type="Button" parent="CenterContainer/VBox"]
unique_name_in_owner = true
layout_mode = 2
custom_minimum_size = Vector2(200, 44)
text = "이어하기"

[node name="SettingsBtn" type="Button" parent="CenterContainer/VBox"]
unique_name_in_owner = true
layout_mode = 2
custom_minimum_size = Vector2(200, 44)
text = "설정"

[node name="QuitBtn" type="Button" parent="CenterContainer/VBox"]
unique_name_in_owner = true
layout_mode = 2
custom_minimum_size = Vector2(200, 44)
text = "종료"

[node name="ConfirmPanel" type="PanelContainer" parent="."]
texture_filter = 2
unique_name_in_owner = true
visible = false
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -150.0
offset_top = -55.0
offset_right = 150.0
offset_bottom = 55.0
grow_horizontal = 2
grow_vertical = 2

[node name="Margin" type="MarginContainer" parent="ConfirmPanel"]
layout_mode = 2
theme_override_constants/margin_left = 12
theme_override_constants/margin_top = 12
theme_override_constants/margin_right = 12
theme_override_constants/margin_bottom = 12

[node name="VBox" type="VBoxContainer" parent="ConfirmPanel/Margin"]
layout_mode = 2
theme_override_constants/separation = 12

[node name="WarningLabel" type="Label" parent="ConfirmPanel/Margin/VBox"]
layout_mode = 2
text = "기존 세이브가 삭제됩니다.
계속하시겠습니까?"
horizontal_alignment = 1

[node name="BtnRow" type="HBoxContainer" parent="ConfirmPanel/Margin/VBox"]
