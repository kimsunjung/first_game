[gd_scene format=3]

[ext_resource type="Script" path="res://Scripts/UI/SkillWindow.cs" id="1_skillwindow"]

[node name="SkillWindow" type="CanvasLayer"]
process_mode = 3
script = ExtResource("1_skillwindow")

[node name="PanelContainer" type="PanelContainer" parent="."]
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -200.0
offset_top = -220.0
offset_right = 200.0
offset_bottom = 220.0
grow_horizontal = 2
grow_vertical = 2

[node name="VBoxContainer" type="VBoxContainer" parent="PanelContainer"]
layout_mode = 2
theme_override_constants/separation = 8

[node name="TitleLabel" type="Label" parent="PanelContainer/VBoxContainer"]
layout_mode = 2
theme_override_font_sizes/font_size = 18
text = "스킬창  [Tab]"
horizontal_alignment = 1

[node name="HintLabel" type="Label" parent="PanelContainer/VBoxContainer"]
layout_mode = 2
theme_override_font_sizes/font_size = 11
text = "Q / W / E / R 키로 사용"
horizontal_alignment = 1
modulate = Color(0.7, 0.7, 0.7, 1.0)

[node name="SkillSlotContainer" type="VBoxContainer" parent="PanelContainer/VBoxContainer"]
unique_name_in_owner = true
layout_mode = 2
theme_override_constants/separation = 6
