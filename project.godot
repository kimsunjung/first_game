; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="first_game"
run/main_scene="res://Scenes/UI/main_menu.tscn"
config/features=PackedStringArray("4.6", "C#", "Mobile")
config/icon="res://icon.svg"
config/quit_on_go_back=false

[autoload]

GameManager="*res://Scripts/Core/GameManager.cs"
AudioManager="*res://Scripts/Core/AudioManager.cs"
SceneManager="*res://Scripts/Core/SceneManager.cs"

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="canvas_items"

[dotnet]

project/assembly_name="first_game"

[editor]

movie_writer/movie_file="D:/개인/개인프로젝트/first-game/play_movie/test.avi"

[input_devices]

pointing/emulate_mouse_from_touch=false

